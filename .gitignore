# Node (if you add a JS tool later)
node_modules/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables
.env
*.env
.env.local

# OS / editor garbage
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Jupyter Notebook checkpoints (in every folder)
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Project-specific
worker-python/weights/
worker-python/weights/**
!/worker-python/weights/.gitkeep    # optional: keep the folder itself if you want it to exist when cloning

# Local media in inputs/ and generated videos in outputs/ (folders tracked via .gitkeep)
worker-python/inputs/*
!worker-python/inputs/.gitkeep
!worker-python/inputs/long_test/
!worker-python/inputs/long_test/.gitkeep
worker-python/outputs/*
!worker-python/outputs/.gitkeep

# Other common large/generated folders you probably also want to ignore
worker-python/runs/
worker-python/logs/
worker-python/output/
worker-python/results/
worker-python/exports/
worker-python/data/
worker-python/datasets/
worker-python/__pycache__/
worker-python/*.pth
worker-python/*.pt
worker-python/*.onnx
worker-python/*.engine
worker-python/*.bin

# Ignore all videos everywhere
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
*.webm

# Nested reference project (not tracked in this repository)
EnvironmentalLitterDetection/
temp_rfdetr_conversion/
temp_yolo_lp_trt_conversion/
# marlin2b-local is published; ignore only large/local artifacts
marlin2b-local/weights/
marlin2b-local/results/
marlin2b-local/__pycache__/
